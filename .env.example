# =========================================================================
# EnglishUp Platform Environment Variables Template
# =========================================================================

# Required: Google AI SDK Gemini API key.
# Powers: AI Tutor Chatbot, qualitative grammar quick check audits, and writing evaluation scoring.
# Note: Keep hidden server-side. Do NOT prefix with VITE_.
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Fallback GPT model processing triggers.
# Powers: Dynamic classroom homework generator backups.
OPENAI_API_KEY=

# Optional: Premium voice generation services.
# Powers: Immersive native listening audio tracks in dictionary.
ELEVENLABS_API_KEY=

# Optional: Microsoft Azure Cognitive speech.
# Powers: Phoneme-level alignment in the phonetic speaking lab.
AZURE_SPEECH_KEY=

# Optional: Media upload server.
# Powers: Profile avatar photos and attachments submission storage.
CLOUDINARY_URL=

# Optional: Serverless durable relational PostgreSQL connection string.
# Powers: Stores user profiles, classrooms schedules, assignment checklists, and streaks.
DATABASE_URL=

# Optional: Better Auth security secret key.
# Powers: Secure Google credentials, authentication sessions, and cookies.
BETTER_AUTH_SECRET=

# Optional: Transactional Email system.
# Powers: Daily study streak notices and classroom homework warnings.
RESEND_API_KEY=

# Optional: Static file storage token.
# Powers: PDF files, student homework, and shared resource attachments.
BLOB_READ_WRITE_TOKEN=
